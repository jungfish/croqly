{
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/recipe/:id", "destination": "/api" },
    { "source": "/createurs/:handle", "destination": "/api" },
    { "source": "/sitemap.xml", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 120,
      "includeFiles": "dist/**"
    }
  }
}
