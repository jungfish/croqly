// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (port 6543) — used at runtime
  directUrl = env("DIRECT_URL") // direct (port 5432) — used by `prisma migrate` only
}

// Shared/global cache row: one per unique Instagram Reel, regardless of how
// many users have saved it. See SavedRecipe for per-user ownership.
model Recipe {
  id                  String        @id @default(cuid())
  title               String
  category            String
  ingredients         String // Will store JSON string
  instructions        String // Will store JSON string
  illustration        String?
  // True while illustration generation is still running in the background
  // (see server/routes/recipes.ts) — persisted so a page reload or a
  // different route into this recipe still knows to retry/poll for it,
  // instead of leaving it stuck on the Instagram thumbnail forever.
  illustrationPending Boolean       @default(false)
  url                 String?       @unique
  videoUrl            String?
  prepTime            String?
  cookTime            String?
  totalTime           String?
  servings            Int           @default(4)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  savedRecipes        SavedRecipe[]
  creatorId           String?
  creator             Creator?      @relation(fields: [creatorId], references: [id])

  @@index([creatorId])
}

// The Instagram account a recipe was scraped from. Nullable link from Recipe
// because recipes created via the photo/OCR upload path (see server/routes/ai.ts
// performOCR) have no Instagram source at all. "claimed" tracks whether the
// creator has taken ownership of their public hub page — see
// /createurs/:handle — not whether they consented to being listed at all
// (that's handled editorially, outside this model, for now).
model Creator {
  id              String   @id @default(cuid())
  instagramHandle String   @unique
  displayName     String?
  avatarUrl       String?
  bio             String?
  claimed         Boolean  @default(false)
  claimedByUserId String?
  // Pending claim state: a code the requesting user must post in their
  // Instagram bio before `claimed`/`claimedByUserId` above are set. Kept
  // separate from the confirmed fields so an abandoned/failed attempt never
  // reads as claimed.
  claimVerificationCode  String?
  claimRequestedByUserId String?
  claimRequestedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  recipes         Recipe[]
}

model SavedRecipe {
  id       String   @id @default(cuid())
  userId   String
  recipeId String
  recipe   Recipe   @relation(fields: [recipeId], references: [id])
  savedAt  DateTime @default(now())

  @@unique([userId, recipeId])
  @@index([userId])
}

// Throttles the expensive path (Instagram fetch + AI) for anonymous callers
// only — cache hits and authenticated users are never rate-limited here.
model AnonymousProcessingLog {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

// Per-user merged shopping list line. Rows are keyed by (userId, name, unit) so
// that adding "200 g de farine" from one recipe and "1 kg de farine" from
// another merges into a single row with a stable id — checked state survives
// further merges. unit is never null: Postgres treats two NULLs as distinct in
// a unique constraint, so an absent/incompatible unit is normalized to ''
// instead (see server/lib/unitConversion.ts).
model ShoppingListItem {
  id              String   @id @default(cuid())
  userId          String
  name            String
  unit            String
  quantity        Float?
  label           String
  checked         Boolean  @default(false)
  sourceRecipeIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, name, unit])
  @@index([userId])
}
